#ifndef GLSL_LIGHT_DIRECTIONAL_H
#define GLSL_LIGHT_DIRECTIONAL_H

float evaluateDirectionalLightPDF(){
	return 1.0f;
}

// Return Direction
vec3 sampleDirectionalLight(uint lightIdx){
	Light light = lights[lightIdx];

	return -normalize(light.direction);
}

vec3 evaluateDirectionalLight(uint lightIdx){
	return lights[lightIdx].emission;
}

#endif // !GLSL_LIGHT_DIRECTIONAL_H